# Copiază acest fișier ca .env pentru dezvoltare locală.
# În Netlify, adaugă aceleași valori în Site configuration > Environment variables.

# Traduceri Azure (principal)
AZURE_TRANSLATOR_KEY=cheia_ta_azure
AZURE_TRANSLATOR_REGION=regiunea_resursei_azure
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com

# Traduceri DeepL (rezervă)
DEEPL_API_KEY=cheia_ta_deepl
DEEPL_API_URL=https://api-free.deepl.com/v2/translate

# Pronunție norvegiană ElevenLabs
ELEVENLABS_API_KEY=cheia_ta_elevenlabs
ELEVENLABS_VOICE_ID=id-ul_vocii_masculine
ELEVENLABS_FEMALE_VOICE_ID=id-ul_vocii_feminine
ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# Evaluarea pronunției Azure Speech (provider principal)
# Folosește cheia și regiunea resursei Speech Free F0 create în Azure.
AZURE_SPEECH_KEY=cheia_resursei_speech
AZURE_SPEECH_REGION=westeurope
AZURE_SPEECH_VOICE=nb-NO-PernilleNeural

# Știri reale din Norvegia
GNEWS_API_KEY=cheia_ta_gnews

# Ultima rezervă pentru traduceri dacă Azure și DeepL nu răspund
MYMEMORY_EMAIL=email@exemplu.com

# Autentificare și progres Supabase (valori publice pentru aplicația React)
VITE_SUPABASE_URL=https://proiectul-tau.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=cheia_publica_supabase

# Nu adăuga niciodată SUPABASE_SERVICE_ROLE_KEY în frontend sau în variabile REACT_APP_*.
