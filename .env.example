# Copiază acest fișier ca .env.local și adaugă cheia ta API
# Pentru știri reale din Norvegia: https://gnews.io/register (gratuit)

REACT_APP_GNEWS_API_KEY=cheia_ta_api_de_la_gnews

# Opțional: email valid pentru MyMemory (traducere știri)
# Fără: 5000 caractere/zi. Cu email: 50000 caractere/zi
REACT_APP_MYMEMORY_EMAIL=email@exemplu.com
